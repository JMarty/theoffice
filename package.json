{
  "name": "theoffice",
  "version": "0.1.0",
  "description": "The Office — a clean, multi-tenant AI agent back-office engine (tmux flat-rate runtime, Slack channel)",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "import:office": "tsx src/migrate-import/import-claudeclaw.ts"
  },
  "dependencies": {
    "@slack/socket-mode": "^2.0.2",
    "@slack/web-api": "^7.8.0",
    "better-sqlite3": "^11.7.0",
    "cron-parser": "^4.9.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
